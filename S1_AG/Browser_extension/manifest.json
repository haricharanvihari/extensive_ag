{
  "manifest_version": 2,
  "name": "URL Time Guard",
  "version": "1.0.0",
  "description": "Track time on selected websites and alert when usage limits are exceeded.",
  "permissions": [
    "tabs",
    "storage",
    "alarms",
    "notifications",
    "downloads"
  ],
  "background": {
    "scripts": [
      "background.js"
    ],
    "persistent": true
  },
  "browser_action": {
    "default_title": "URL Time Guard",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.svg",
      "32": "icons/icon-32.svg"
    }
  },
  "options_ui": {
    "page": "options.html",
    "browser_style": true,
    "open_in_tab": true
  },
  "icons": {
    "16": "icons/icon-16.svg",
    "32": "icons/icon-32.svg",
    "48": "icons/icon-48.svg",
    "96": "icons/icon-96.svg"
  }
}
