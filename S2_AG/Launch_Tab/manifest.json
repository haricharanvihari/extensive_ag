{
  "manifest_version": 3,
  "name": "Tab Catcher & Session Manager",
  "version": "1.0",
  "description": "Capture all open tabs, categorize them with Gemini AI, and reopen them later.",
  "permissions": [
    "tabs",
    "storage",
    "unlimitedStorage",
    "downloads"
  ],
  "host_permissions": [
    "https://generativelanguage.googleapis.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "48": "icon.png"
    }
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "tabcatcher@gravityproj.local"
    }
  }
}
